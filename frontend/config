[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/ddsw-mn/2026-1c-frontend-mn-grupo-08.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
[branch "fix-filtros-busqueda"]
	remote = origin
	merge = refs/heads/fix-filtros-busqueda
[branch "feature/ui-disponibilidades"]
